            xticklabels=[&#39;Não Tóxico&#39;, &#39;Tóxico&#39;], yticklabels=[&#39;Não Tóxico&#39;, &#39;Tóxico&#39;])
plt.title(f&#39;Matriz de Confusão\nAcurácia: {acc:.0%}&#39;, fontsize=22)
plt.xticks(fontsize=12)
plt.yticks(fontsize=12)
plt.xlabel(&#39;Previsto&#39;, fontsize=14)
