<pre class="r"><code>sleep %&gt;% 
  arrange(end) %&gt;% 
  mutate(Date = as.Date(end))%&gt;%
  # complete(Date = seq.Date(min(Date), max(Date), by=&quot;day&quot;))  %&gt;%  
  visdat::vis_dat() </code></pre>
